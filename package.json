{
  "name": "cpl-ai",
  "version": "1.0.1",
  "description": "CPL-AI: Cyber Programming Language - AI Native. AI is a first-class language feature, not a library.",
  "main": "dist/cli/index.js",
  "bin": {
    "cpl": "./bin/cpl.js"
  },
  "scripts": {
    "build":              "tsc",
    "build:exe":          "pkg dist/cli/index.js --targets node18-win-x64,node18-linux-x64,node18-macos-x64 --output release/cpl",
    "build:all":          "npm run build && npm run build:exe",
    "dev":                "ts-node src/cli/index.ts",
    "playground:backend": "cd playground/backend && npm run dev",
    "playground:frontend": "cd playground/frontend && npm run dev",
    "test":               "jest",
    "prepublishOnly":     "npm run build"
  },
  "pkg": {
    "assets": ["dist/**/*"],
    "targets": ["node18-win-x64", "node18-linux-x64", "node18-macos-x64"],
    "outputPath": "release"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "openai":            "^4.0.0",
    "chalk":             "^4.1.2",
    "commander":         "^11.0.0",
    "dotenv":            "^16.0.0",
    "uuid":              "^9.0.0",
    "readline":          "^1.3.0"
  },
  "devDependencies": {
    "@types/node":  "^20.0.0",
    "@types/uuid":  "^9.0.0",
    "concurrently": "^8.0.0",
    "ts-node":      "^10.9.0",
    "typescript":   "^5.0.0",
    "jest":         "^29.0.0",
    "@types/jest":  "^29.0.0",
    "ts-jest":      "^29.0.0"
  },
  "files": [
    "bin/**/*",
    "dist/**/*",
    "examples/**/*",
    "LANGUAGE_SPEC.md",
    "README.md",
    ".env.example"
  ],
  "keywords": [
    "cpl-ai", "programming-language", "ai-native", "cyber",
    "agents", "llm", "anthropic", "ai-first", "dsl"
  ],
  "homepage":   "https://github.com/guea14012/cpl-ai",
  "repository": { "type": "git", "url": "https://github.com/guea14012/cpl-ai.git" },
  "bugs":       { "url": "https://github.com/guea14012/cpl-ai/issues" },
  "author":     "KoppaZZZ",
  "license":    "MIT",
  "engines":    { "node": ">=18.0.0" }
}

