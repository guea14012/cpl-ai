# CPL-AI Environment Configuration

# AI Provider (anthropic | openai | local)
CPL_PROVIDER=anthropic

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Model to use
CPL_MODEL=claude-sonnet-4-6

# Debug mode
CPL_DEBUG=false

# Max tokens per AI call
CPL_MAX_TOKENS=4096

# Rate limit (calls per minute)
CPL_RATE_LIMIT=60

# Log file path
CPL_LOG_FILE=./cpl-audit.log

# Memory backend (memory | file)
CPL_MEMORY_BACKEND=memory
CPL_MEMORY_FILE=./cpl-memory.json
